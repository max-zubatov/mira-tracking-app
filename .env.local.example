# Supabase — get from https://supabase.com/dashboard/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic — get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Steel — browser automation for scraping career pages
# Find your key at https://app.steel.dev/settings/api-keys
STEEL_API_KEY=ste-...

# Serper — Google Search API (2,500 free searches/month)
# Get your key at https://serper.dev
SERPER_API_KEY=your-serper-key
